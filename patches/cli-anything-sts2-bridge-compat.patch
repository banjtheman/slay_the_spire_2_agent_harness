+    private static void ForcePastEmptyRewardsOverlay()
+    {
+        var overlay = NOverlayStack.Instance?.Peek();
+        if (overlay is not NRewardsScreen rewardsScreen)
+            return;
+
+        var remainingRewards = FindAll<NRewardButton>(rewardsScreen)
+            .Where(b => b.IsEnabled && b.Reward != null)
+            .ToList();
+        if (remainingRewards.Count > 0 && !HasOnlyUnclaimablePotionRewards(remainingRewards))
+            return;
+
+        TryCompleteRewardsScreen(rewardsScreen, FindFirst<NProceedButton>(rewardsScreen));
+
+        var runState = RunManager.Instance.DebugOnlyGetState();
+        if (runState?.CurrentRoom is not MapRoom)
+            RunManager.Instance.EnterRoom(new MapRoom()).GetAwaiter().GetResult();
+    }
+
+    private static bool HasOnlyUnclaimablePotionRewards(List<NRewardButton> rewardButtons)
+    {
+        if (rewardButtons.Count == 0)
+            return false;
+        if (rewardButtons.Any(button => button.Reward is not PotionReward))
+            return false;
+
+        var runState = RunManager.Instance.DebugOnlyGetState();
+        if (runState == null)
+            return false;
+        var player = LocalContext.GetMe(runState);
+        if (player == null)
+            return false;
+        return player.PotionSlots.Count > 0 && player.PotionSlots.All(slot => slot != null);
+    }
+
+    private static void TryCompleteRewardsScreen(NRewardsScreen rewardsScreen, NProceedButton? proceedButton)
+    {
+        try
+        {
+            if (proceedButton != null)
+            {
+                var method = rewardsScreen.GetType().GetMethod(
+                    "OnProceedButtonPressed",
+                    BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);
+                method?.Invoke(rewardsScreen, new object?[] { proceedButton });
+            }
+        }
+        catch { }
+
+        try
+        {
+            var prop = rewardsScreen.GetType().GetProperty(
+                "IsComplete",
+                BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);
+            prop?.SetValue(rewardsScreen, true);
+        }
+        catch
+        {
+            try
+            {
+                var field = rewardsScreen.GetType().GetField(
+                    "<IsComplete>k__BackingField",
+                    BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);
+                field?.SetValue(rewardsScreen, true);
+            }
+            catch { }
+        }
+
+        try { NOverlayStack.Instance?.Remove(rewardsScreen); }
+        catch { }
+    }
