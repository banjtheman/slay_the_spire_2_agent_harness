+        }
+        catch { }
+
+        try
+        {
+            var prop = rewardsScreen.GetType().GetProperty(
+                "IsComplete",
+                BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);
+            prop?.SetValue(rewardsScreen, true);
+        }
+        catch
+        {
+            try
+            {
+                var field = rewardsScreen.GetType().GetField(
+                    "<IsComplete>k__BackingField",
+                    BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);
+                field?.SetValue(rewardsScreen, true);
+            }
+            catch { }
+        }
+
+        try { NOverlayStack.Instance?.Remove(rewardsScreen); }
+        catch { }
+    }
